# Frontend environment example
# Copy this file to .env.local (or .env) and fill in real values.

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
BACKEND_URL=http://127.0.0.1:8000

# NextAuth
NEXTAUTH_SECRET=your-nextauth-secret
AZURE_AD_TENANT_ID=your-azure-ad-tenant-id
AZURE_AD_CLIENT_ID=your-azure-ad-client-id
AZURE_AD_CLIENT_SECRET=your-azure-ad-client-secret

# Backend proxy API key (must match backend API_KEY)
SECRET_API_KEY=your-backend-api-key

# PostgreSQL (used by frontend API routes)
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_HOST=your-db-host
DB_PORT=your-db-port
DB_NAME=your-db-name
# Optional alternative to DB_* values
DATABASE_URL=postgresql://your-db-user:your-db-password@your-db-host:your-db-port/your-db-name?sslmode=require

# Azure/Cosmos and Storage
COSMOS_DB_ENDPOINT=your-cosmos-db-endpoint
COSMOS_DB_KEY=your-cosmos-db-key
COSMOS_DB_NAME=your-cosmos-db-name
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_ACCOUNT_NAME=your-azure-storage-account-name
AZURE_STORAGE_ACCOUNT_KEY=your-azure-storage-account-key

# Mail and notifications
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com
SERVICE_EMAIL_ADDRESS=service-account@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=your-smtp-port
GMAIL_USERNAME=your-smtp-username
GMAIL_PASSWORD=your-smtp-password
# Optional fallback names used by some mail helper code
EMAIL_USER=your-email-user
EMAIL_PASS=your-email-pass

# Meetings behavior
MEETING_PROVIDER=your-meeting-provider
MEETING_SMTP_FALLBACK=your-meeting-smtp-fallback
